# ==========================================
# Local Development Configuration
# ==========================================
# Complete, self-contained profile for local development.
# Services run on localhost. No authentication, local filesystem storage.
#
# Quick start:
#   cp .env.local.example .env
#   just env-setup && just env-github
# ==========================================

# ==========================================
# API Credentials (Required)
# ==========================================

# GitHub token for repository operations
# GITHUB_TOKEN=your_github_token

# Anthropic API key for Guide (or use `fit-guide login` for OAuth)
# ANTHROPIC_API_KEY=sk-ant-...

# MCP bearer token for Guide MCP endpoint (generated by `fit-guide init`)
# MCP_TOKEN=your_generated_mcp_token

# ==========================================
# Service Authentication (Required)
# ==========================================

# HMAC secret for inter-service authentication (32-character string)
# Generate with: node scripts/secret.js
# SERVICE_SECRET=your_generated_secret_here

# ==========================================
# Database Credentials
# ==========================================

# DATABASE_PASSWORD=your_database_password

# ==========================================
# Core Services
# ==========================================

SERVICE_TRACE_URL=grpc://localhost:3001
SERVICE_VECTOR_URL=grpc://localhost:3002
SERVICE_GRAPH_URL=grpc://localhost:3003
SERVICE_PATHWAY_URL=grpc://localhost:3004
SERVICE_MCP_URL=http://localhost:3005
# SERVICE_MSTEAMS_URL=http://localhost:3978

# ==========================================
# MS Teams Bot (Optional)
# ==========================================
# Required only when running the Teams ↔ Kata agent bridge (services/msteams).
# See services/msteams/SETUP.md and specs/1200-teams-agent-bridge/config-msteams.md.

# Azure AD app registration credentials
# MICROSOFT_APP_ID=
# MICROSOFT_APP_PASSWORD=
# MICROSOFT_APP_TENANT_ID=

# Repository the bridge dispatches workflow_dispatch events to
# SERVICE_MSTEAMS_GITHUB_REPO=owner/repo

# Public tunnel URL (no trailing slash) — both the Bot Framework messaging
# endpoint and GitHub Actions callback webhook route through this.
# SERVICE_MSTEAMS_CALLBACK_BASE_URL=https://your-tunnel-domain

# ==========================================
# Embedding Service (Optional)
# ==========================================
# gRPC endpoint for the embedding service (wraps TEI internally).
# Start with: just tei-start

SERVICE_EMBEDDING_URL=grpc://localhost:3007

# ==========================================
# Supabase (single instance — all products)
# ==========================================
SUPABASE_URL=http://127.0.0.1:54321
# Generated by `just env-setup`:
# SUPABASE_JWT_SECRET=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ==========================================
# Storage — Local filesystem (default)
# ==========================================

STORAGE_TYPE=local

# ==========================================
# GetDX API (Map activity pipeline)
# ==========================================

# GETDX_API_TOKEN=your_getdx_api_token
GETDX_BASE_URL=https://api.getdx.com

# ==========================================
# Debug (Optional)
# ==========================================

# Enable debug logging for all components
DEBUG=*

# Or enable for specific components
# DEBUG=mcp,graph
