# ==========================================
# Local Development Configuration
# ==========================================
# Complete, self-contained profile for local development.
# Services run on localhost. No authentication, local filesystem storage.
#
# Quick start:
#   cp .env.local.example .env
#   just env-secrets && just env-storage && just env-github
# ==========================================

# ==========================================
# API Credentials (Required)
# ==========================================

# GitHub token for repository operations
# GITHUB_TOKEN=your_github_token

# GitHub token for LLM API (required for all operations)
# Generate with: node scripts/env-github.js
# Must have 'models' scope to access GitHub Models API
# LLM_TOKEN=your_github_token_with_models_scope

# GitHub Models API base URL (required)
# For org-level PATs: https://models.github.ai/orgs/{YOUR_ORG}
# For user-level PATs: https://models.github.ai
# LLM_BASE_URL=https://models.github.ai/orgs/your-org

# ==========================================
# Service Authentication (Required)
# ==========================================

# HMAC secret for inter-service authentication (32-character string)
# Generate with: node scripts/secret.js
# SERVICE_SECRET=your_generated_secret_here

# JWT secret for extension authentication (HS256 signing key)
# JWT_SECRET=your_hs256_signing_secret

# JWT anonymous key for unauthenticated access (HS256 signing key)
# JWT_ANON_KEY=your_jwt_anon_key

# JWT token expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRY=3600

# ==========================================
# Database Credentials
# ==========================================

# DATABASE_PASSWORD=your_database_password

# ==========================================
# Extension Services
# ==========================================

EXTENSION_UI_URL=http://localhost:3000
EXTENSION_WEB_URL=http://localhost:3001/web/api
# EXTENSION_API_URL=http://localhost:3979
# EXTENSION_API_SECRET=your_api_secret

# ==========================================
# Core Services
# ==========================================

SERVICE_AGENT_URL=grpc://localhost:3002
SERVICE_MEMORY_URL=grpc://localhost:3003
SERVICE_LLM_URL=grpc://localhost:3004
SERVICE_VECTOR_URL=grpc://localhost:3005
SERVICE_GRAPH_URL=grpc://localhost:3006
SERVICE_TOOL_URL=grpc://localhost:3007
SERVICE_TRACE_URL=grpc://localhost:3008

# ==========================================
# Embedding Service (Optional)
# ==========================================
# Falls back to LLM_BASE_URL (OpenAI-compatible /embeddings endpoint).
# Override only when running a local TEI instance.
# Requires TEI to be running: cargo install text-embeddings-router

# EMBEDDING_BASE_URL=http://localhost:8090

# ==========================================
# Map Supabase (local)
# ==========================================

MAP_SUPABASE_URL=http://127.0.0.1:54321
MAP_SUPABASE_DB_PORT=54322

# ==========================================
# Optional: Teams Extension
# ==========================================

# EXTENSION_TEAMSAPP_BOT_ID=fi
# EXTENSION_TEAMSAPP_BOT_DOMAIN=your_domain
# EXTENSION_TEAMSAPP_APP_PORT=3978
# EXTENSION_TEAMSAPP_MASTER_KEY=your_master_key
# EXTENSION_TEAMSAPP_MICROSOFT_APP_TYPE=SingleTenant
# EXTENSION_TEAMSAPP_MICROSOFT_APP_TENANT_ID=your_tenant_id
# EXTENSION_TEAMSAPP_MICROSOFT_APP_ID=your_app_id
# EXTENSION_TEAMSAPP_MICROSOFT_APP_PASSWORD=your_app_password

# ==========================================
# Optional: Example Tool Service
# ==========================================

# SERVICE_HASH_URL=grpc://localhost:3009

# ==========================================
# Authentication — None (default for local dev)
# ==========================================

AUTH_TYPE=none
EXTENSION_WEB_AUTH_ENABLED=false

# To switch to GoTrue auth locally, replace the two lines above with:
# AUTH_TYPE=gotrue
# JWT_AUTH_URL=http://localhost:9999
# EXTENSION_WEB_AUTH_ENABLED=true

# ==========================================
# Storage — Local filesystem (default)
# ==========================================

STORAGE_TYPE=local

# ==========================================
# GetDX API (Map activity pipeline)
# ==========================================

# GETDX_API_TOKEN=your_getdx_api_token
GETDX_BASE_URL=https://api.getdx.com

# ==========================================
# Debug (Optional)
# ==========================================

# Enable debug logging for all components
DEBUG=*

# Or enable for specific components
# DEBUG=agent,memory
