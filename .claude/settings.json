{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": ["Edit(.claude/**)", "Write(.claude/**)"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "make install"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "make memory-commit"
          }
        ]
      }
    ]
  }
}
