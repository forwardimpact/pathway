# Wiki (cloned on demand by scripts/wiki-sync.sh, not tracked)
wiki/

# Development files
tmp/
SCRATCHPAD*.md

# CLI output
output/

# Claude Code local settings (per-machine, not shared)
.claude/settings.local.json

# Built static site
public/

# Built documentation
dist/

# Website SVG assets (copied from design/ at build time)
websites/**/*.svg

# Outpost build output
products/outpost/dist/
*.bun-build

# Test files
test-results/
playwright-report/

# Package files
node_modules/
package-lock.json

