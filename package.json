{
  "name": "forwardimpact-monorepo",
  "version": "0.5.0",
  "private": true,
  "description": "Applications that help teams grow and cultivate world-class engineers in the age of AI",
  "homepage": "https://www.forwardimpact.team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forwardimpact/monorepo.git"
  },
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "type": "module",
  "workspaces": [
    "libraries/*",
    "products/*",
    "services/*"
  ],
  "scripts": {
    "prestart": "bunx fit-pathway build",
    "start": "bunx serve public",
    "dev": "bunx fit-pathway dev",
    "check": "bun run format && bun run lint && bun run jsdoc && bun run invariants && bun run context && bun run wiki",
    "wiki": "bunx fit-wiki audit",
    "wiki:fix": "bunx fit-wiki fix",
    "check:fix": "bun run format:fix && bun run lint:fix && bun run context:fix && bun run wiki:fix",
    "jsdoc": "eslint",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "invariants": "bun run invariants:check-workspace-imports && bun run invariants:check-libmock && bun run invariants:check-node-floor && bun run invariants:check-temporal && bun run invariants:check-ambient-deps && bun run invariants:check-subprocess-in-tests",
    "invariants:check-workspace-imports": "bun scripts/check-workspace-imports.mjs",
    "invariants:check-libmock": "bun scripts/check-libmock.mjs",
    "invariants:check-node-floor": "bun scripts/check-node-floor.mjs",
    "invariants:check-temporal": "node scripts/check-temporal.mjs",
    "invariants:check-ambient-deps": "node scripts/check-ambient-deps.mjs",
    "invariants:check-subprocess-in-tests": "node scripts/check-subprocess-in-tests.mjs",
    "capture-cli-golden": "node scripts/capture-cli-golden.mjs",
    "test": "find ./tests ./libraries ./products ./services ./.github/workflows/test ./.claude/skills/kata-interview/test -name '*.test.js' -not -path '*/node_modules/*' | xargs bun test",
    "test:e2e": "bunx playwright test",
    "generate": "fit-terrain build",
    "data": "bun run data:check-prose && bun run data:check-schema",
    "data:check-prose": "bunx fit-terrain check",
    "data:check-schema": "LOG_LEVEL=error bunx fit-terrain validate && LOG_LEVEL=error bunx fit-map validate --data products/map/starter",
    "context": "bun run context:check-instructions && bun run context:check-metadata && bun run context:check-jtbd && bun run context:check-dependabot",
    "context:check-instructions": "bunx coaligned instructions",
    "context:check-metadata": "bun scripts/check-metadata.mjs",
    "context:check-jtbd": "bunx coaligned jtbd",
    "context:check-dependabot": "bun scripts/check-dependabot.mjs",
    "context:fix": "bun scripts/check-metadata.mjs --fix && bunx coaligned jtbd --fix"
  },
  "dependencies": {
    "forwardimpact-monorepo": "."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.60.0",
    "acorn": "^8.16.0",
    "eslint": "^10.4.0",
    "eslint-plugin-jsdoc": "^63.0.0",
    "semver": "^7.8.1",
    "serve": "^14.2.6",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@hono/node-server": "^2.0.2",
    "brace-expansion": "^5.0.6",
    "fast-uri": "^3.1.2",
    "fast-xml-builder": "^1.1.7",
    "hono": "^4.12.18",
    "ip-address": "^10.2.0",
    "lodash": "^4.18.0",
    "postcss": "^8.5.10",
    "protobufjs": "^7.5.8",
    "qs": "^6.15.2",
    "tmp": "^0.2.6",
    "uuid": "^11.1.1",
    "ws": "^8.20.1"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22.0.0"
  }
}
