{
  "name": "forwardimpact-monorepo",
  "version": "0.5.0",
  "private": true,
  "description": "Applications that help teams grow and cultivate world-class engineers in the age of AI",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/forwardimpact/monorepo"
  },
  "homepage": "https://www.forwardimpact.team",
  "type": "module",
  "workspaces": [
    "libraries/*",
    "products/*",
    "services/*"
  ],
  "scripts": {
    "prestart": "bunx fit-pathway build",
    "start": "bunx serve public",
    "dev": "bunx fit-pathway dev",
    "check": "bun run format & p1=$!; bun run lint & p2=$!; bun run test & p3=$!; bun run validate -- --json & p4=$!; wait $p1 && wait $p2 && wait $p3 && wait $p4",
    "check:fix": "bun run format:fix && bun run lint:fix",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check --log-level warn .",
    "format:fix": "prettier --write .",
    "test": "find ./tests ./libraries ./products ./services -name '*.test.js' -not -path '*/node_modules/*' | xargs bun run node --test --test-concurrency=0",
    "test:e2e": "bunx playwright test",
    "validate": "bunx fit-map validate",
    "generate": "fit-universe"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.8.1",
    "serve": "^14.2.6"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.81.0",
    "lodash": "^4.18.0"
  }
}
