{
  "name": "forwardimpact-monorepo",
  "version": "0.5.0",
  "private": true,
  "description": "Applications that help teams grow and cultivate world-class engineers in the age of AI",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/forwardimpact/monorepo"
  },
  "homepage": "https://www.forwardimpact.team",
  "type": "module",
  "workspaces": [
    "products/map",
    "libraries/libskill",
    "libraries/libui",
    "products/pathway",
    "products/basecamp",
    "libraries/libdoc",
    "libraries/libsecret",
    "libraries/libindex",
    "libraries/libtelemetry",
    "libraries/libutil",
    "libraries/libtype",
    "libraries/libconfig",
    "libraries/libstorage",
    "libraries/libpolicy",
    "libraries/librpc",
    "libraries/libllm",
    "libraries/libagent",
    "libraries/libgraph",
    "libraries/libmemory",
    "libraries/libresource",
    "libraries/libvector",
    "libraries/libharness",
    "libraries/libcodegen",
    "libraries/libsupervise",
    "libraries/librc",
    "libraries/libformat",
    "libraries/librepl",
    "libraries/libtool",
    "libraries/libweb",
    "libraries/libtemplate",
    "libraries/libprompt",
    "libraries/libsyntheticgen",
    "libraries/libsyntheticprose",
    "libraries/libsyntheticrender",
    "libraries/libeval",
    "libraries/libuniverse",
    "products/guide",
    "services/agent",
    "services/graph",
    "services/llm",
    "services/memory",
    "services/tool",
    "services/trace",
    "services/vector",
    "services/web"
  ],
  "scripts": {
    "prestart": "bunx fit-pathway build",
    "start": "bunx serve public",
    "dev": "bunx fit-pathway dev",
    "check": "bun run format & bun run lint & bun run test & bun run validate -- --json & wait",
    "check:fix": "bun run format:fix && bun run lint:fix",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "find ./tests ./libraries ./products ./services -name '*.test.js' -not -path '*/node_modules/*' | xargs bun run node --test",
    "test:e2e": "bunx playwright test",
    "validate": "bunx fit-map validate",
    "generate": "fit-universe"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.8.1",
    "serve": "^14.2.6"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
