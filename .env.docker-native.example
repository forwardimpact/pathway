# ==========================================
# Docker Native Configuration
# ==========================================
# Complete, self-contained profile for Docker Compose with GoTrue auth
# and MinIO storage.
#
# Quick start:
#   cp .env.docker-native.example .env
#   just env-secrets && just env-storage && just env-github
# ==========================================

# ==========================================
# API Credentials (Required)
# ==========================================

# GitHub token for repository operations
# GITHUB_TOKEN=your_github_token

# Anthropic API key for Guide (or use `fit-guide login` for OAuth)
# ANTHROPIC_API_KEY=sk-ant-...

# MCP bearer token for Guide MCP endpoint (generated by `fit-guide init`)
# MCP_TOKEN=your_generated_mcp_token

# ==========================================
# Service Authentication (Required)
# ==========================================

# HMAC secret for inter-service authentication (32-character string)
# Generate with: node scripts/secret.js
# SERVICE_SECRET=your_generated_secret_here

# JWT secret for extension authentication (HS256 signing key)
# JWT_SECRET=your_hs256_signing_secret

# JWT anonymous key for unauthenticated access (HS256 signing key)
# JWT_ANON_KEY=your_jwt_anon_key

# JWT token expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRY=3600

# ==========================================
# Database Credentials
# ==========================================

# DATABASE_PASSWORD=your_database_password

# ==========================================
# Proxy Configuration
# ==========================================
# Required for containers to access external APIs through the gateway.

HTTPS_PROXY=http://gateway.local:3128
HTTP_PROXY=http://gateway.local:3128
NO_PROXY=localhost,127.0.0.1,*.local

# ==========================================
# Embedding Service (Optional)
# ==========================================
# Used by the vector service for query embeddings and by fit-process-vectors.

# EMBEDDING_BASE_URL=http://tei.local:8080

# ==========================================
# Map Supabase (docker)
# ==========================================

MAP_SUPABASE_URL=http://supabase-kong.local:8000
MAP_SUPABASE_DB_PORT=5432

# ==========================================
# Authentication — GoTrue
# ==========================================

AUTH_TYPE=gotrue
JWT_AUTH_URL=http://auth-gotrue.local:9999
EXTENSION_WEB_AUTH_ENABLED=true

# ==========================================
# Storage — MinIO (S3-compatible)
# ==========================================

STORAGE_TYPE=s3
S3_REGION=us-east-1
S3_BUCKET_NAME=data
AWS_ENDPOINT_URL=http://storage-minio.local:9000
# AWS_ACCESS_KEY_ID=your_s3_access_key
# AWS_SECRET_ACCESS_KEY=your_s3_secret_key

# ==========================================
# Extension Services (docker URLs)
# ==========================================

EXTENSION_UI_URL=http://localhost:3000
EXTENSION_WEB_URL=http://localhost:3005/web/api

# ==========================================
# Core Services (docker URLs)
# ==========================================

SERVICE_TRACE_URL=grpc://localhost:3001
SERVICE_VECTOR_URL=grpc://localhost:3002
SERVICE_GRAPH_URL=grpc://localhost:3003
SERVICE_PATHWAY_URL=grpc://localhost:3004
SERVICE_MCP_URL=http://localhost:3006

# ==========================================
# GetDX API (Map activity pipeline)
# ==========================================

# GETDX_API_TOKEN=your_getdx_api_token
GETDX_BASE_URL=https://api.getdx.com

# ==========================================
# Debug (Optional)
# ==========================================

# Enable debug logging for all components
DEBUG=*

# Or enable for specific components
# DEBUG=mcp,graph
