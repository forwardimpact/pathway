[
  {
    "name": "--help",
    "args": ["--help"],
    "exitCode": 0,
    "stdoutFile": "help.stdout.txt",
    "stderrFile": "help.stderr.txt",
    "transform": [
      {
        "pattern": "fit-svscan [0-9]+\\.[0-9]+\\.[0-9]+",
        "replacement": "fit-svscan X.Y.Z"
      }
    ]
  },
  {
    "name": "--version",
    "args": ["--version"],
    "exitCode": 0,
    "stdoutFile": "version.stdout.txt",
    "stderrFile": "version.stderr.txt",
    "transform": [
      {
        "pattern": "[0-9]+\\.[0-9]+\\.[0-9]+",
        "replacement": "X.Y.Z"
      }
    ]
  }
]
