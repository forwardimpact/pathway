{
  "name": "@forwardimpact/libsupervise",
  "version": "0.1.21",
  "description": "Process supervision (restart policies, log rotation) driven by JSON daemon manifests agents can read and tune; built on `libconfig` for settings loading.",
  "keywords": [
    "supervisor",
    "process",
    "daemon",
    "agent"
  ],
  "homepage": "https://www.forwardimpact.team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forwardimpact/monorepo.git",
    "directory": "libraries/libsupervise"
  },
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "forwardimpact": {
    "capability": "agent-infrastructure",
    "needs": [
      "Supervise a long-running daemon",
      "Configure restart policies and log rotation for a daemon manifest"
    ]
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./bin/fit-logger.js": "./bin/fit-logger.js",
    "./bin/fit-svscan.js": "./bin/fit-svscan.js"
  },
  "bin": {
    "fit-logger": "./bin/fit-logger.js",
    "fit-svscan": "./bin/fit-svscan.js"
  },
  "files": [
    "src/**/*.js",
    "bin/**/*.js",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "bun test test/*.test.js"
  },
  "dependencies": {
    "@forwardimpact/libcli": "^0.1.0",
    "@forwardimpact/libtelemetry": "^0.1.22"
  },
  "devDependencies": {
    "@forwardimpact/libharness": "^0.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
