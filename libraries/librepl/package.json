{
  "name": "@forwardimpact/librepl",
  "version": "0.1.10",
  "description": "Agent-friendly interactive REPL with command dispatch and skill-doc links surfaced in `--help`.",
  "keywords": [
    "repl",
    "cli",
    "agent",
    "interactive"
  ],
  "homepage": "https://www.forwardimpact.team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forwardimpact/monorepo.git",
    "directory": "libraries/librepl"
  },
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "forwardimpact": {
    "capability": "agent-capability",
    "needs": [
      "Run an interactive REPL session",
      "Surface skill-doc links in REPL --help output"
    ]
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/**/*.js",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "bun test test/*.test.js"
  },
  "dependencies": {
    "@forwardimpact/libformat": "^0.1.0"
  },
  "devDependencies": {
    "@forwardimpact/libharness": "^0.1.14"
  },
  "publishConfig": {
    "access": "public"
  }
}
