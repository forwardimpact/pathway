[
  {
    "name": "help",
    "args": ["--help"],
    "exitCode": 0,
    "stdoutFile": "help.stdout.txt",
    "stderrFile": "help.stderr.txt"
  },
  {
    "name": "version",
    "args": ["--version"],
    "exitCode": 0,
    "stdoutFile": "version.stdout.txt",
    "stderrFile": "version.stderr.txt",
    "transform": [{ "pattern": "\\d+\\.\\d+\\.\\d+", "replacement": "X.Y.Z" }]
  },
  {
    "name": "no-command",
    "args": [],
    "exitCode": 2,
    "stdoutFile": "no-command.stdout.txt",
    "stderrFile": "no-command.stderr.txt"
  },
  {
    "name": "report-empty",
    "args": ["report", "--input", "test/golden/fit-benchmark/empty-runs"],
    "exitCode": 1,
    "stdoutFile": "report-empty.stdout.txt",
    "stderrFile": "report-empty.stderr.txt",
    "transform": [
      {
        "pattern": "\\d{4}-\\d{2}-\\d{2}T[\\d:.]+Z",
        "replacement": "<TS>"
      },
      {
        "pattern": "benchmark main \\d+",
        "replacement": "benchmark main <PID>"
      },
      { "pattern": "ENOENT[^\\n]*", "replacement": "ENOENT <normalized>" }
    ]
  }
]
