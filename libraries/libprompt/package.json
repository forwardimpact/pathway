{
  "name": "@forwardimpact/libprompt",
  "version": "0.1.6",
  "description": "Agent-authored prompt templates loaded from .prompt.md files with Mustache substitution.",
  "keywords": [
    "prompt",
    "template",
    "mustache",
    "agent",
    "llm"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/forwardimpact/monorepo",
    "directory": "libraries/libprompt"
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./loader": "./src/loader.js"
  },
  "files": [
    "src/**/*.js",
    "README.md"
  ],
  "dependencies": {
    "mustache": "^4.2.0"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
