{
  "name": "@forwardimpact/libtemplate",
  "version": "0.2.8",
  "description": "Mustache template loader with project-level override directories for agent-rendered content.",
  "keywords": [
    "template",
    "mustache",
    "render",
    "agent"
  ],
  "forwardimpact": {
    "capability": "agent-capability",
    "needs": [
      "Render a Mustache template with project overrides"
    ]
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/forwardimpact/monorepo",
    "directory": "libraries/libtemplate"
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./loader": "./src/loader.js"
  },
  "files": [
    "src/**/*.js",
    "README.md"
  ],
  "dependencies": {
    "mustache": "^4.2.0"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
