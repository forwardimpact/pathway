{
  "name": "@forwardimpact/libui",
  "version": "1.2.0",
  "description": "Agent-friendly web surfaces — SPA routing, reactive state, and route-to-CLI bindings that share handler logic across web and terminal.",
  "keywords": [
    "ui",
    "dom",
    "spa",
    "router",
    "agent"
  ],
  "homepage": "https://www.forwardimpact.team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forwardimpact/monorepo.git",
    "directory": "libraries/libui"
  },
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "forwardimpact": {
    "capability": "agent-capability",
    "needs": [
      "Build a reactive single-page web app"
    ]
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./render": "./src/render.js",
    "./reactive": "./src/reactive.js",
    "./state": "./src/state.js",
    "./errors": "./src/errors.js",
    "./error-boundary": "./src/error-boundary.js",
    "./router-core": "./src/router-core.js",
    "./router-pages": "./src/router-pages.js",
    "./router-slides": "./src/router-slides.js",
    "./yaml-loader": "./src/yaml-loader.js",
    "./markdown": "./src/markdown.js",
    "./utils": "./src/utils.js",
    "./invocation-context": "./src/invocation-context.js",
    "./route-descriptor": "./src/route-descriptor.js",
    "./bound-router": "./src/bound-router.js",
    "./command-bar": "./src/command-bar.js",
    "./json-ld-script": "./src/json-ld-script.js",
    "./components": "./src/components/index.js",
    "./components/*": "./src/components/*.js",
    "./css/*": "./src/css/*"
  },
  "files": [
    "src/**/*.js",
    "src/components/",
    "src/css/",
    "README.md"
  ],
  "scripts": {
    "test": "bun test test/*.test.js"
  },
  "devDependencies": {
    "happy-dom": "^20.9.0"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
