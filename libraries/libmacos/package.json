{
  "name": "@forwardimpact/libmacos",
  "version": "0.1.0",
  "description": "macOS bundle assembly, code signing, and OS permission entitlement helpers — desktop delivery for agent products.",
  "keywords": [
    "macos",
    "bundle",
    "codesign",
    "agent"
  ],
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "forwardimpact": {
    "capability": "foundations",
    "needs": [
      "Assemble a macOS app bundle",
      "Code-sign a macOS app",
      "Declare macOS permission entitlements for an app"
    ]
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./posix-spawn": "./src/posix-spawn.js",
    "./tcc-responsibility": "./src/tcc-responsibility.js"
  },
  "files": [
    "src/**/*.js",
    "scripts/**/*.sh",
    "templates/**"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "test": "bun test test/*.test.js"
  },
  "devDependencies": {
    "@forwardimpact/libharness": "^0.1.14"
  },
  "publishConfig": {
    "access": "public"
  }
}
