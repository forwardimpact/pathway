{
  "name": "@forwardimpact/libgraph",
  "version": "0.1.65",
  "description": "RDF graph index and processing utilities",
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./index/graph.js": "./src/index/graph.js",
    "./processor/graph.js": "./src/processor/graph.js"
  },
  "bin": {
    "fit-process-graphs": "./bin/fit-process-graphs.js",
    "fit-subjects": "./bin/fit-subjects.js",
    "fit-query": "./bin/fit-query.js"
  },
  "files": [
    "src/**/*.js",
    "bin/**/*.js",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "bun run node --test test/*.test.js"
  },
  "keywords": [
    "rdf",
    "graph",
    "linked-data"
  ],
  "dependencies": {
    "@forwardimpact/libcli": "^0.1.0",
    "@forwardimpact/libindex": "^0.1.27",
    "@forwardimpact/libstorage": "^0.1.53",
    "@forwardimpact/libtelemetry": "^0.1.22",
    "@forwardimpact/libtype": "^0.1.63",
    "n3": "^2.0.3"
  },
  "devDependencies": {
    "@forwardimpact/libutil": "^0.1.60",
    "@forwardimpact/libharness": "^0.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
