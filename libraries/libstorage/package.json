{
  "name": "@forwardimpact/libstorage",
  "version": "0.1.72",
  "description": "Pluggable file storage (local, S3, Supabase) for context agents fetch and produce at runtime.",
  "keywords": [
    "storage",
    "s3",
    "supabase",
    "agent",
    "retrieval"
  ],
  "homepage": "https://www.forwardimpact.team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forwardimpact/monorepo.git",
    "directory": "libraries/libstorage"
  },
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "forwardimpact": {
    "capability": "agent-retrieval",
    "needs": [
      "Store files to local, S3, or Supabase",
      "Read or write JSONL"
    ]
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./bin/fit-storage.js": "./bin/fit-storage.js"
  },
  "bin": {
    "fit-storage": "./bin/fit-storage.js"
  },
  "files": [
    "src/**/*.js",
    "bin/**/*.js",
    "README.md"
  ],
  "scripts": {
    "test": "bun test test/*.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@forwardimpact/libcli": "^0.1.0",
    "@aws-sdk/credential-providers": "^3.1040.0",
    "@forwardimpact/libconfig": "^0.1.58",
    "@forwardimpact/libsecret": "^0.1.3",
    "@forwardimpact/libtelemetry": "^0.1.22",
    "@forwardimpact/libutil": "^0.1.60"
  },
  "devDependencies": {
    "@forwardimpact/libharness": "^0.1.5"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
