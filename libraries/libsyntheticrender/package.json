{
  "name": "@forwardimpact/libsyntheticrender",
  "version": "0.1.19",
  "description": "Multi-format rendering and validation of synthetic agent evaluation data (HTML, Markdown, YAML).",
  "keywords": [
    "synthetic",
    "render",
    "validation",
    "agent",
    "eval"
  ],
  "homepage": "https://www.forwardimpact.team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forwardimpact/monorepo.git",
    "directory": "libraries/libsyntheticrender"
  },
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "forwardimpact": {
    "capability": "agent-self-improvement",
    "needs": [
      "Render synthetic data as HTML, Markdown, or YAML",
      "Validate synthetic data integrity"
    ]
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./render/html": "./src/render/html.js",
    "./render/pathway": "./src/render/pathway.js",
    "./render/raw": "./src/render/raw.js",
    "./render/markdown": "./src/render/markdown.js",
    "./render/dataset-renderers": "./src/render/dataset-renderers.js",
    "./validate": "./src/validate.js",
    "./format": "./src/format.js"
  },
  "files": [
    "src/**/*.js",
    "templates/**",
    "README.md"
  ],
  "dependencies": {
    "@forwardimpact/libsyntheticgen": "^0.1.0",
    "@forwardimpact/libtemplate": "^0.2.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@forwardimpact/libharness": "^0.1.14"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "optionalDependencies": {
    "apache-arrow": "^21.1.0",
    "parquet-wasm": "^0.7.1"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
