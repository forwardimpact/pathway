{
  "name": "@forwardimpact/libsecret",
  "version": "0.1.12",
  "description": "Secret generation, JWT signing, and `.env` file management for agent services and CLIs.",
  "keywords": [
    "secret",
    "jwt",
    "env",
    "credential",
    "agent"
  ],
  "homepage": "https://www.forwardimpact.team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forwardimpact/monorepo.git",
    "directory": "libraries/libsecret"
  },
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "forwardimpact": {
    "capability": "foundations",
    "needs": [
      "Generate a secret (random token or API key)",
      "Sign a JWT",
      "Read or write .env (dotenv) files"
    ]
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/**/*.js",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "bun test test/*.test.js"
  },
  "publishConfig": {
    "access": "public"
  }
}
