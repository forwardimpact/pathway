{
  "name": "@forwardimpact/libutil",
  "version": "0.1.77",
  "description": "Cross-cutting utilities for agents and services: retry with backoff, hashing, token counting, project finder, tarball downloader.",
  "keywords": [
    "util",
    "retry",
    "hash",
    "tokens",
    "agent"
  ],
  "forwardimpact": {
    "capability": "foundations",
    "needs": [
      "Compute a stable hash (SHA-256 checksum)",
      "Count LLM tokens",
      "Find the project root",
      "Retry a flaky network call",
      "Download and extract a tarball",
      "Generate a UUID"
    ]
  },
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./bin/fit-download-bundle.js": "./bin/fit-download-bundle.js",
    "./bin/fit-tiktoken.js": "./bin/fit-tiktoken.js"
  },
  "bin": {
    "fit-download-bundle": "./bin/fit-download-bundle.js",
    "fit-tiktoken": "./bin/fit-tiktoken.js"
  },
  "files": [
    "src/**/*.js",
    "bin/**/*.js",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "bun test test/*.test.js"
  },
  "dependencies": {
    "@forwardimpact/libcli": "^0.1.0",
    "@forwardimpact/libtelemetry": "^0.1.22"
  },
  "devDependencies": {
    "@forwardimpact/libharness": "^0.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
