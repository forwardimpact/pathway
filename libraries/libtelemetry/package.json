{
  "name": "@forwardimpact/libtelemetry",
  "version": "0.1.36",
  "description": "OpenTelemetry-based tracing library for Guide microservices",
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
