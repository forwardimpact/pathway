{
  "name": "@forwardimpact/libharness",
  "version": "0.1.17",
  "description": "Shared mocks and test fixtures so every agent service tests the same way.",
  "keywords": [
    "test",
    "mock",
    "fixture",
    "harness",
    "agent"
  ],
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./mock": "./src/mock/index.js",
    "./fixture": "./src/fixture/index.js"
  },
  "files": [
    "src/**/*.js",
    "README.md"
  ],
  "scripts": {
    "test": "bun test test/*.test.js"
  },
  "author": "Forward Impact Team",
  "license": "MIT",
  "peerDependencies": {
    "@forwardimpact/libtype": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  }
}
