{
  "name": "@forwardimpact/libvector",
  "version": "0.1.90",
  "description": "Vector dot-product scoring — find semantically related content without a dedicated database.",
  "keywords": [
    "vector",
    "cosine-similarity",
    "embedding",
    "agent",
    "retrieval"
  ],
  "homepage": "https://www.forwardimpact.team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forwardimpact/monorepo.git",
    "directory": "libraries/libvector"
  },
  "license": "Apache-2.0",
  "author": "D. Olsson <hi@senzilla.io>",
  "jobs": [
    {
      "user": "Platform Builders",
      "goal": "Ground Agents in Context",
      "trigger": "Adding semantic search to a tool and realizing it needs a vector database just to score a few hundred embeddings.",
      "bigHire": "find semantically related content without a dedicated database.",
      "littleHire": "score a query against an index and get ranked results in memory.",
      "competesWith": "external vector databases; keyword search instead of semantic; skipping retrieval entirely"
    }
  ],
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./index/vector.js": "./src/index/vector.js",
    "./processor/vector.js": "./src/processor/vector.js"
  },
  "bin": {
    "fit-process-vectors": "./bin/fit-process-vectors.js",
    "fit-search": "./bin/fit-search.js"
  },
  "files": [
    "src/**/*.js",
    "bin/**/*.js",
    "README.md"
  ],
  "scripts": {
    "test": "bun test test/*.test.js"
  },
  "dependencies": {
    "@forwardimpact/libcli": "^0.1.0",
    "@forwardimpact/libindex": "^0.1.27",
    "@forwardimpact/libtelemetry": "^0.1.22",
    "@forwardimpact/libtype": "^0.1.63"
  },
  "devDependencies": {
    "@forwardimpact/libutil": "^0.1.60",
    "@forwardimpact/libharness": "^0.1.14"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
