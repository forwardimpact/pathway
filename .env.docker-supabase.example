# ==========================================
# Docker Supabase Configuration
# ==========================================
# Complete, self-contained profile for Docker Compose with Supabase storage.
#
# Quick start:
#   cp .env.docker-supabase.example .env
#   just env-setup && just env-github
# ==========================================

# ==========================================
# API Credentials (Required)
# ==========================================

# GitHub token for repository operations
# GITHUB_TOKEN=

# Anthropic API key for Guide (or use `fit-guide login` for OAuth)
# ANTHROPIC_API_KEY=

# AWS credentials for S3-compatible storage (e.g., MinIO)
# When using local MinIO, these are generated by `just env-setup`
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# MCP bearer token for the MCP service endpoint, generated by `just env-setup`
# MCP_TOKEN=

# HMAC secret for inter-service authentication, generated by `just env-setup`
# SERVICE_SECRET=

# Database credentials for PostgreSQL, generated by `just env-setup`
# DATABASE_PASSWORD=

# ==========================================
# Proxy Configuration
# ==========================================
# Required for containers to access external APIs through the gateway.

HTTPS_PROXY=http://gateway.local:3128
HTTP_PROXY=http://gateway.local:3128
NO_PROXY=localhost,127.0.0.1,*.local

# ==========================================
# Core Services
# ==========================================

SERVICE_TRACE_URL=grpc://localhost:3001
SERVICE_VECTOR_URL=grpc://localhost:3002
SERVICE_GRAPH_URL=grpc://localhost:3003
SERVICE_PATHWAY_URL=grpc://localhost:3004
SERVICE_MCP_URL=http://localhost:3005
# SERVICE_MSBRIDGE_URL=http://localhost:3978

# ==========================================
# MS Teams Bot (Optional)
# ==========================================
# Required only when running the Teams ↔ Kata agent bridge (services/msbridge).
# See services/msbridge/README.md

# Azure AD app registration credentials
# MICROSOFT_APP_ID=
# MICROSOFT_APP_TENANT_ID=
# MICROSOFT_APP_PASSWORD=

# Bridge configuration (no trailing slashes on URLs)
# SERVICE_MSBRIDGE_GITHUB_REPO=
# SERVICE_MSBRIDGE_CALLBACK_BASE_URL=

# ==========================================
# GitHub Discussions Bridge (Optional)
# ==========================================
# Required when running the Discussions ↔ Kata agent bridge (services/ghbridge).
# See services/ghbridge/README.md

# Kata Agent Team GitHub App credentials
# SERVICE_GHBRIDGE_APP_ID=
# SERVICE_GHBRIDGE_APP_INSTALLATION_ID=
# SERVICE_GHBRIDGE_APP_PRIVATE_KEY=
# SERVICE_GHBRIDGE_APP_WEBHOOK_SECRET=

# Bridge configuration (no trailing slashes on URLs)
# SERVICE_GHBRIDGE_URL=http://localhost:8080
# SERVICE_GHBRIDGE_GITHUB_REPO=
# SERVICE_GHBRIDGE_CALLBACK_BASE_URL=

# ==========================================
# GitHub User Auth (Optional)
# ==========================================
# Required when running per-user GitHub auth (services/ghauth + services/oauth).
# See services/ghauth/README.md

# Kata Agent User GitHub App credentials
# SERVICE_GHAUTH_CLIENT_ID=
# SERVICE_GHAUTH_CLIENT_SECRET=

# Auth service configuration (no trailing slashes on URLs)
# SERVICE_GHAUTH_URL=grpc://localhost:3006
# SERVICE_GHAUTH_LINK_BASE_URL=
# SERVICE_OAUTH_URL=http://localhost:3007

# ==========================================
# Embedding Service (Optional)
# ==========================================
# gRPC endpoint for the embedding service (wraps TEI internally).
# Start with: just tei-start

# SERVICE_EMBEDDING_URL=grpc://embedding.local:3007

# ==========================================
# Supabase (single instance — all products)
# ==========================================
SUPABASE_URL=http://supabase-kong.local:8000
# Generated by `just env-setup`:
# SUPABASE_JWT_SECRET=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ==========================================
# Storage — Supabase (S3-compatible)
# ==========================================

STORAGE_TYPE=supabase
S3_REGION=local
S3_BUCKET_NAME=data
AWS_ENDPOINT_URL=http://storage-supabase.local:5000/s3

# ==========================================
# GetDX API (Map activity pipeline)
# ==========================================

# GETDX_API_TOKEN=
GETDX_BASE_URL=https://api.getdx.com

# ==========================================
# Debug (Optional)
# ==========================================

# Enable debug logging for all components
DEBUG=*

# Or enable for specific components
# DEBUG=mcp,graph
