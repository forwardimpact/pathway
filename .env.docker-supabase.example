# ==========================================
# Docker Supabase Configuration
# ==========================================
# Complete profile for Docker Compose with Supabase auth and storage.
# Copy to .env.docker-supabase or append to .env.
#
# Combined from:
#   .env.docker.example            — proxy, embedding, map supabase (docker URLs)
#   .env.auth.supabase.example     — AUTH_TYPE=supabase, JWT_AUTH_URL, web auth
#   .env.storage.supabase.example  — STORAGE_TYPE=supabase, S3/AWS config (docker URLs)
# ==========================================

# ==========================================
# Proxy Configuration
# ==========================================
# Required for containers to access external APIs through the gateway.

HTTPS_PROXY=http://gateway.local:3128
HTTP_PROXY=http://gateway.local:3128
NO_PROXY=localhost,127.0.0.1,*.local

# ==========================================
# Embedding Service (TEI)
# ==========================================

EMBEDDING_BASE_URL=http://tei.local:8080

# ==========================================
# Map Supabase (docker)
# ==========================================

MAP_SUPABASE_URL=http://supabase-kong.local:8000
MAP_SUPABASE_DB_PORT=5432

# ==========================================
# Authentication — Supabase Auth
# ==========================================

AUTH_TYPE=supabase
JWT_AUTH_URL=http://auth-supabase.local:9999
EXTENSION_WEB_AUTH_ENABLED=true

# ==========================================
# Storage — Supabase (S3-compatible)
# ==========================================

STORAGE_TYPE=supabase
S3_REGION=local
S3_BUCKET_NAME=data

# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_jwt
# MAP_SUPABASE_SERVICE_ROLE_KEY=your_map_service_role_key_jwt
# MAP_SUPABASE_ANON_KEY=your_map_anon_key_jwt

AWS_ENDPOINT_URL=http://storage-supabase.local:5000/s3
# AWS_ACCESS_KEY_ID=your_s3_access_key
# AWS_SECRET_ACCESS_KEY=your_s3_secret_key

# ==========================================
# Extension Services (docker URLs)
# ==========================================

EXTENSION_UI_URL=http://localhost:3000
EXTENSION_WEB_URL=http://localhost:3001/web/api

# ==========================================
# Core Services (docker URLs)
# ==========================================

SERVICE_AGENT_URL=grpc://localhost:3002
SERVICE_MEMORY_URL=grpc://localhost:3003
SERVICE_LLM_URL=grpc://localhost:3004
SERVICE_VECTOR_URL=grpc://localhost:3005
SERVICE_GRAPH_URL=grpc://localhost:3006
SERVICE_TOOL_URL=grpc://localhost:3007
SERVICE_TRACE_URL=grpc://localhost:3008
