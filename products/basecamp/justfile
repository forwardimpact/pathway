# Basecamp — build, install, and manage the scheduler

app_name       := "fit-basecamp"
launcher       := "Basecamp"
version        := `grep '"version"' package.json | head -1 | sed 's/.*: *"//;s/".*//;s/ //g'`
plist_name     := "com.forwardimpact.basecamp"
dist_dir       := "dist"

# Show available recipes
[doc("List all available recipes")]
default:
    @just --list

# ─── Build ────────────────────────────────────────────────────────────────────

# Copy fit-* skills from monorepo .claude/skills/ into templates.
# For local testing only — the build script (pkg/build.js) does this automatically.
prepare-template:
    #!/usr/bin/env bash
    set -e
    src="../../.claude/skills"
    dest="templates/.claude/skills"
    count=0
    for d in "$src"/fit-*/; do
        [ -d "$d" ] || continue
        name="$(basename "$d")"
        rm -rf "$dest/$name"
        cp -R "$d" "$dest/$name"
        echo "  Copied $name"
        count=$((count + 1))
    done
    echo "  -> $count skills copied"

# Compile standalone scheduler binary
build-scheduler:
    @mkdir -p "{{ dist_dir }}"
    bun build --compile \
        --outfile "{{ dist_dir }}/{{ app_name }}" src/basecamp.js

# Compile Swift app launcher (includes status menu UI)
build-launcher:
    @mkdir -p "{{ dist_dir }}"
    @rm -rf macos/Basecamp/.build
    swift build -c release --package-path macos/Basecamp
    @cp macos/Basecamp/.build/release/{{ launcher }} "{{ dist_dir }}/{{ launcher }}"
    @rm -rf macos/Basecamp/.build

# Compile everything (scheduler first so launcher binary is not embedded)
build: prepare-template build-scheduler build-launcher

# Assemble Basecamp.app bundle
build-app: build
    #!/usr/bin/env bash
    set -euo pipefail
    ICON_DIR="../../design/icons"
    bash ../../libraries/libmacos/scripts/build-app.sh \
      --bundle-name "Basecamp" \
      --primary-exec "{{ dist_dir }}/{{ launcher }}" \
      --extra-exec "{{ dist_dir }}/{{ app_name }}" \
      --info-plist "macos/Info.plist" \
      --entitlements "macos/Basecamp.entitlements" \
      --resource "config" \
      --resource "templates" \
      --resource "$ICON_DIR/basecamp-flat.svg" \
      --resource "$ICON_DIR/basecamp.svg" \
      --version "{{ version }}" \
      --out-dir "{{ dist_dir }}"

# Build macOS installer package (.pkg)
pkg: build-app
    bash pkg/macos/build-pkg.sh "{{ dist_dir }}" "{{ version }}"

# Clean build artifacts
clean:
    sudo rm -rf "{{ dist_dir }}"
    rm -rf macos/Basecamp/.build

# ─── Setup ───────────────────────────────────────────────────────────────────

# Uninstall (remove app; user data preserved)
uninstall:
    bash pkg/macos/uninstall.sh

# ─── Scheduler ────────────────────────────────────────────────────────────────

# Run due tasks once and exit
run:
    bun src/basecamp.js

# Run scheduler daemon (poll every 60s)
daemon:
    bun src/basecamp.js --daemon

# Run a specific task immediately
run-task task:
    bun src/basecamp.js --run "{{ task }}"

# Show knowledge bases and task status
status:
    bun src/basecamp.js --status

# Initialize a new knowledge base at the given path
init path:
    bun src/basecamp.js --init "{{ path }}"
