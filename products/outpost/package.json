{
  "name": "@forwardimpact/outpost",
  "version": "2.12.6",
  "description": "Claude Code-native personal knowledge system with autonomous agents",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/forwardimpact/monorepo",
    "directory": "products/outpost"
  },
  "homepage": "https://www.forwardimpact.team/outpost",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "fit-outpost": "./bin/fit-outpost.js"
  },
  "scripts": {
    "start": "bun ./bin/fit-outpost.js",
    "status": "bun ./bin/fit-outpost.js status",
    "build": "bun pkg/build.js",
    "build:app": "bun pkg/build.js --app",
    "build:pkg": "bun pkg/build.js --pkg"
  },
  "files": [
    "bin/**/*.js",
    "src/**/*.js",
    "config/",
    "templates/"
  ],
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@forwardimpact/libcli": "^0.1.0",
    "@forwardimpact/libmacos": "^0.1.0",
    "@forwardimpact/libtelemetry": "^0.1.33"
  },
  "publishConfig": {
    "access": "public"
  }
}
